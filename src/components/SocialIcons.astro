---
import { Icon } from "astro-icon/components";

type LinkType = {
  id: string;
  URL: string;
  iconName: string;
  color: string;
};

const LINKS: LinkType[] = [
  {
    id: "twitter",
    URL: "https://twitter.com/the_yugandharr",
    iconName: "fa-brands:twitter",
    color: "#1da1f2",
  },
  {
    id: "instagram",
    URL: "https://www.instagram.com/the_yugandharr/",
    iconName: "fa-brands:instagram",
    color: "#C13584",
  },
  {
    id: "github",
    URL: "https://github.com/YugandharrPatil",
    iconName: "fa-brands:github",
    color: "#5D6BC1",
  },
  {
    id: "email",
    URL: "mailto:yugandharrpatil@gmail.com",
    iconName: "fa-regular:envelope",
    color: "#94a3b8",
  },
];
---

<div class="mt-8 flex gap-2 max-xl:justify-center">
  {LINKS.map((link) => (
    <a target="_blank" href={link.URL} class="block text-slate-100 hover:text-slate-400 transition duration-300 ease-in-out">
      <Icon
        name={link.iconName}
        class="mx-2 h-[30px] w-[30px] transition duration-300 ease-in-out"
        style={{ color: link.color }}
      />
    </a>
  ))}
</div>
