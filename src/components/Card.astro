---
import { cn } from "@/lib/utils";

interface Props {
  className?: string;
  [key: string]: any;
}

const { className, ...attrs } = Astro.props;
---
<div class={cn("rounded-xl border border-neutral-200 bg-white text-neutral-950 shadow-sm dark:border-neutral-800 dark:bg-neutral-950 dark:text-neutral-50 w-fit px-6 pb-4", className)} {...attrs}>
  <slot />
</div>
